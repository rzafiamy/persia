# ══════════════════════════════════════════════════════════════════
#  Persia — Environment Configuration Example
#  Copy this file to .env and fill in your values.
#  Priority: CLI flags > .env (cwd) > ~/.config/persia/.env > config.json > defaults
# ══════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────
# PROVIDER — LLM API Connection
# ─────────────────────────────────────────────────────────────────

# Your API key. Persia also accepts OPENAI_API_KEY and LEMURA_API_KEY.
PERSIA_API_KEY=your_api_key_here

# Base URL of the OpenAI-compatible API endpoint.
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   Groq:        https://api.groq.com/openai/v1
#   Together:    https://api.together.xyz/v1
#   Mistral:     https://api.mistral.ai/v1
#   LM Studio:   http://localhost:1234/v1
PERSIA_BASE_URL=https://api.openai.com/v1

# Default model name. Must match a model available at your provider.
# Examples: gpt-4o, gpt-4o-mini, llama3.2, mistral-large-latest,
#           llama-3.3-70b-versatile, Qwen/Qwen2.5-72B-Instruct
PERSIA_MODEL=gpt-4o-mini


# ─────────────────────────────────────────────────────────────────
# CONTEXT & TOKEN LIMITS
# ─────────────────────────────────────────────────────────────────

# Total context window size for the model (in tokens).
# Set to match your model's actual context window.
# gpt-4o = 128000 | llama3.2 = 131072 | gpt-4o-mini = 128000
PERSIA_MAX_TOKENS=16384

# Maximum tokens to generate per completion (one agent response).
# Higher = longer outputs; lower = faster/cheaper.
PERSIA_MAX_COMPLETION_TOKENS=4096

# Maximum number of tool-call steps per user turn.
# Prevents runaway loops. Increase for very complex tasks (e.g. 40).
PERSIA_MAX_STEPS=20

# HTTP request timeout for each LLM call (seconds).
PERSIA_TIMEOUT=30

# Maximum retry attempts on transient API errors.
PERSIA_MAX_RETRIES=3


# ─────────────────────────────────────────────────────────────────
# BEHAVIOUR
# ─────────────────────────────────────────────────────────────────

# Stream tokens to the console in real-time (true/false).
PERSIA_STREAMING=true

# Show tool call names and arguments as the agent works (true/false).
PERSIA_SHOW_TOOL_CALLS=true

# Maximum conversation turns to keep in memory before compression.
PERSIA_MAX_HISTORY=50

# Custom system prompt. Leave blank to use the default Persia persona.
# Tip: wrap in single quotes if your prompt contains spaces.
# PERSIA_SYSTEM_PROMPT=You are a senior DevOps engineer...


# ─────────────────────────────────────────────────────────────────
# TOOL CATEGORIES — Enable / Disable
# ─────────────────────────────────────────────────────────────────

# Allow shell command execution (run_command, run_python).
# Set to false for read-only / safer sessions.
PERSIA_ALLOW_SHELL=true

# Allow writing, moving, copying, and deleting files.
# Set to false to make Persia read-only on the filesystem.
PERSIA_ALLOW_FILE_WRITE=true

# Allow web tools (web_search, fetch_url, download_file, get_ip_info).
PERSIA_ALLOW_WEB=true

# Allow clipboard and desktop tools (notify, open_url, open_file).
PERSIA_ALLOW_DESKTOP=true


# ─────────────────────────────────────────────────────────────────
# TOOL FIREWALL — pylemura Security Layer
# ─────────────────────────────────────────────────────────────────
# The firewall intercepts every tool call and applies rules.
# Default decision when no rule matches: accept | deny | ask
# "ask" pauses the agent and prompts you in the terminal.

PERSIA_FIREWALL_DEFAULT=accept

# Comma-separated list of tool names that always require confirmation.
# Example: delete_file,run_command,kill_process
PERSIA_FIREWALL_ASK_TOOLS=delete_file,kill_process

# Comma-separated list of tool names that are always blocked.
PERSIA_FIREWALL_DENY_TOOLS=

# Comma-separated list of tools that are always allowed without prompt.
PERSIA_FIREWALL_ALLOW_TOOLS=


# ─────────────────────────────────────────────────────────────────
# TOOL EXECUTION BUDGET — Rate Limiting
# ─────────────────────────────────────────────────────────────────

# Maximum total tool calls across the entire session (0 = unlimited).
PERSIA_BUDGET_MAX_TOTAL_CALLS=0

# Per-tool call limits. Format: tool_name:limit,tool_name:limit
# Example: run_command:10,web_search:5,delete_file:3
PERSIA_BUDGET_PER_TOOL=

# Maximum characters a single tool response may return before truncation.
# Prevents huge outputs from flooding the context window.
PERSIA_MAX_TOKENS_PER_TOOL=8000


# ─────────────────────────────────────────────────────────────────
# CONTEXT COMPRESSION — pylemura Memory Management
# ─────────────────────────────────────────────────────────────────

# Strategy: sandwich | history | none
# sandwich = keep first N + last M turns, summarise middle
# history  = keep only last N turns
PERSIA_COMPRESSION_STRATEGY=sandwich

# Trigger compression when context is this % full (0.0–1.0).
PERSIA_COMPRESSION_TRIGGER=0.80

# Turns to preserve at the start of conversation (sandwich mode).
PERSIA_COMPRESSION_PRESERVE_FIRST=2

# Turns to preserve at the end of conversation (sandwich / history mode).
PERSIA_COMPRESSION_PRESERVE_LAST=6

# Maximum tokens for the compression summary injected into context.
PERSIA_COMPRESSION_SUMMARY_TOKENS=600


# ─────────────────────────────────────────────────────────────────
# LOGGING & OBSERVABILITY
# ─────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
# debug shows all pylemura internals (token counts, compressions, etc.)
PERSIA_LOG_LEVEL=warn

# Log file path. Leave blank to log to stderr only.
# PERSIA_LOG_FILE=~/.config/persia/persia.log


# ─────────────────────────────────────────────────────────────────
# SHELL TOOL SAFETY
# ─────────────────────────────────────────────────────────────────

# Maximum seconds a shell command may run before being killed.
PERSIA_SHELL_TIMEOUT=30

# Maximum seconds a Python snippet may run before being killed.
PERSIA_PYTHON_TIMEOUT=30


# ─────────────────────────────────────────────────────────────────
# STANDARD ALIASES (also accepted by Persia)
# ─────────────────────────────────────────────────────────────────
# These are checked as fallbacks if PERSIA_* variables are not set.

# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# LEMURA_API_KEY=
# LEMURA_BASE_URL=
# LEMURA_MODEL=
